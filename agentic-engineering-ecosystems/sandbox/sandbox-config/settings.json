    "skipDangerousModePermissionPrompt": true
  },
  "autoCompactEnabled": true,
  "trustedDirectories": [
    "/home/agent",
    "/home/agent/work"
  ],
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
